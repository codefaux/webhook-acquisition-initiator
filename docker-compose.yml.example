services:
  webhook-acquisition-initiator:
    container_name: wai
    image: wai
    # build:
    #   context: .
    #   dockerfile: Dockerfile
    ports:
      - "8000:8000"
    environment:
      SONARR_URL: http://sonarr:8989/
      SONARR_API: UNSET  # Replace with your actual API key
      WAI_CONFIG_FILE: /conf/wai.toml
    volumes:
      - ./data:/data
      - ./output:/output
